# Copie este arquivo para `.env` e ajuste o IP local da sua máquina (caso precise acessar via celular)
# Descubra o IP com `ipconfig` (Windows) e atualize abaixo (ex.: http://192.168.0.12:8000). Se for usar só no mesmo PC,
# deixe http://127.0.0.1:8000 ou http://localhost:8000.
# Valor usado pelo app para chamar o backend. Ambos os nomes são suportados.
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
