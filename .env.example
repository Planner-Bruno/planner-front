# Copie este arquivo para `.env` e ajuste o IP local da sua máquina
# Descubra o IP com `ipconfig` (Windows) e atualize abaixo (ex.: http://192.168.0.12:8000)
# Valor usado pelo app para chamar o backend. Ambos os nomes são suportados.
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.10:8000
EXPO_PUBLIC_API_URL=http://192.168.0.10:8000
